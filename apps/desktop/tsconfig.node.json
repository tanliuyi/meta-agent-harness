{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": ["electron.vite.config.*", "src/main/**/*", "src/preload/**/*", "src/shared/**/*"],
  "compilerOptions": {
    "composite": false,
    "noEmit": true,
    "noUnusedParameters": false,
    "allowImportingTsExtensions": true,
    "types": ["electron-vite/node"],
    "paths": {
      "@earendil-works/pi-agent-core": [
        "../../node_modules/.pnpm/node_modules/@earendil-works/pi-agent-core/dist/index.d.ts"
      ],
      "@earendil-works/pi-ai": ["../../packages/ai/dist/index.d.ts"],
      "@earendil-works/pi-ai/*": [
        "../../packages/ai/dist/*.d.ts",
        "../../packages/ai/dist/providers/*.d.ts"
      ],
      "@coding-agent-src/*": ["../../packages/coding-agent/src/*"],
      "@coding-agent-desktop-src/*": ["../../packages/coding-agent-desktop/src/*"],
      "@earendil-works/pi-coding-agent": ["../../packages/coding-agent/dist/index.d.ts"],
      "@earendil-works/pi-coding-agent-desktop": [
        "../../packages/coding-agent-desktop/src/index.ts"
      ],
      "@earendil-works/pi-coding-agent-desktop/*": ["../../packages/coding-agent-desktop/src/*"],
      "@shared/*": ["./src/shared/*"]
    }
  }
}
