{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": ["electron.vite.config.*", "src/main/**/*", "src/preload/**/*", "src/shared/**/*"],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["electron-vite/node"],
    "paths": {
      "@earendil-works/pi-agent-core": [
        "../../node_modules/.pnpm/node_modules/@earendil-works/pi-agent-core/dist/index.d.ts"
      ],
      "@earendil-works/pi-ai": [
        "../../packages/ai/dist/index.d.ts"
      ],
      "@earendil-works/pi-ai/*": [
        "../../packages/ai/dist/*.d.ts",
        "../../packages/ai/dist/providers/*.d.ts"
      ],
      "@shared/*": [
        "./src/shared/*"
      ]
    }
  }
}
