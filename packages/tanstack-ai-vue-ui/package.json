{
  "name": "@tanstack/ai-vue-ui",
  "version": "0.2.31",
  "description": "Headless Vue components for building TanStack AI chat interfaces with streamed message parts.",
  "author": "Tanner Linsley",
  "license": "MIT",
  "homepage": "https://tanstack.com/ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TanStack/ai.git",
    "directory": "packages/ai-vue-ui"
  },
  "bugs": {
    "url": "https://github.com/TanStack/ai/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/tannerlinsley"
  },
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "clean": "premove ./build ./dist",
    "test": "vitest run --passWithNoTests",
    "test:build": "publint --strict",
    "test:eslint": "eslint ./src",
    "test:lib": "vitest --passWithNoTests",
    "test:lib:dev": "pnpm test:lib --watch",
    "test:types": "vue-tsc --noEmit"
  },
  "keywords": [
    "ai",
    "ai-sdk",
    "typescript",
    "tanstack",
    "vue",
    "chat",
    "ui",
    "headless",
    "components",
    "streaming",
    "generative-ai"
  ],
  "dependencies": {
    "@crazydos/vue-markdown": "^1.1.4",
    "@tanstack/ai-vue": "0.14.3",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "peerDependencies": {
    "vue": ">=3.5.0"
  },
  "devDependencies": {
    "@tanstack/vite-config": "0.4.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/coverage-v8": "4.0.14",
    "premove": "^4.0.0",
    "publint": "^0.3.15",
    "vite": "^7.3.3",
    "vitest": "^4.0.14",
    "vue": "^3.5.25",
    "vue-tsc": "^2.2.10"
  }
}
