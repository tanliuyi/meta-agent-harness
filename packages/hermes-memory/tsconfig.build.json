{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": false,
    "noCheck": true,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noImplicitReturns": false,
    "esModuleInterop": true
  },
  "include": ["src/**/*.ts"]
}
