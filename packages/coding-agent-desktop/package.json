{
  "name": "@earendil-works/pi-coding-agent-desktop",
  "version": "0.80.2",
  "description": "Desktop protocol, worker runtime, and IPC bridge for pi coding agent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ipc/*": {
      "types": "./dist/ipc/*.d.ts",
      "import": "./dist/ipc/*.js"
    },
    "./protocol/*": {
      "types": "./dist/protocol/*.d.ts",
      "import": "./dist/protocol/*.js"
    },
    "./protocol/commands/*": {
      "types": "./dist/protocol/commands/*.d.ts",
      "import": "./dist/protocol/commands/*.js"
    },
    "./protocol/events/*": {
      "types": "./dist/protocol/events/*.d.ts",
      "import": "./dist/protocol/events/*.js"
    },
    "./storage/*": {
      "types": "./dist/storage/*.d.ts",
      "import": "./dist/storage/*.js"
    },
    "./transport/*": {
      "types": "./dist/transport/*.d.ts",
      "import": "./dist/transport/*.js"
    },
    "./worker/*": {
      "types": "./dist/worker/*.d.ts",
      "import": "./dist/worker/*.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "tsgo -p tsconfig.build.json",
    "test": "vitest --run",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "workspace:^",
    "@earendil-works/pi-ai": "workspace:^",
    "@silvia-odwyer/photon-node": "0.3.4",
    "chalk": "5.6.2",
    "cross-spawn": "7.0.6",
    "diff": "8.0.4",
    "get-east-asian-width": "1.6.0",
    "glob": "13.0.6",
    "highlight.js": "10.7.3",
    "hosted-git-info": "9.0.3",
    "ignore": "7.0.5",
    "jiti": "2.7.0",
    "minimatch": "10.2.5",
    "marked": "18.0.5",
    "proper-lockfile": "4.1.2",
    "semver": "7.8.0",
    "typebox": "1.1.38",
    "undici": "8.5.0",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "6.0.6",
    "@types/diff": "7.0.2",
    "@types/hosted-git-info": "3.0.5",
    "@types/node": "24.12.4",
    "@types/proper-lockfile": "4.1.4",
    "@types/semver": "7.7.1",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "shx": "0.4.0",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  },
  "keywords": [
    "coding-agent",
    "desktop",
    "electron",
    "agent"
  ],
  "author": "Mario Zechner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/earendil-works/pi.git",
    "directory": "packages/coding-agent-desktop"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
